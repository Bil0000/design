{
  "$schema": "design-engine.token.schema.v1",
  "name": "editorial",
  "version": "1.0.0",
  "modes": ["light", "dark"],
  "default_mode": "light",
  "color": {
    "primitive": {
      "grey": {
        "0": "oklch(1 0 0)", "50": "oklch(0.985 0.005 60)", "100": "oklch(0.965 0.008 60)",
        "200": "oklch(0.920 0.010 60)", "300": "oklch(0.840 0.012 60)", "400": "oklch(0.700 0.012 60)",
        "500": "oklch(0.560 0.012 60)", "600": "oklch(0.430 0.010 60)", "700": "oklch(0.330 0.010 60)",
        "800": "oklch(0.230 0.008 60)", "900": "oklch(0.150 0.006 60)", "950": "oklch(0.100 0.005 60)"
      },
      "accent": {
        "50": "oklch(0.970 0.030 22)", "200": "oklch(0.880 0.130 22)", "400": "oklch(0.700 0.190 22)",
        "500": "oklch(0.580 0.220 22)", "600": "oklch(0.500 0.220 22)", "700": "oklch(0.420 0.190 22)", "900": "oklch(0.300 0.130 22)"
      },
      "success": "oklch(0.500 0.150 145)", "warning": "oklch(0.650 0.165 65)",
      "error":   "oklch(0.500 0.220 22)",  "info":    "oklch(0.520 0.150 240)",
      "chart": { "1": "oklch(0.500 0.220 22)", "2": "oklch(0.560 0.170 65)", "3": "oklch(0.500 0.150 145)", "4": "oklch(0.640 0.150 95)", "5": "oklch(0.500 0.180 290)", "6": "oklch(0.620 0.180 30)", "7": "oklch(0.520 0.140 200)", "8": "oklch(0.430 0.012 60)" }
    },
    "semantic": {
      "light": {
        "bg-base": "{color.primitive.grey.50}", "bg-surface": "{color.primitive.grey.0}", "bg-elevated": "{color.primitive.grey.0}",
        "bg-overlay": "{color.primitive.grey.100}", "bg-inset": "{color.primitive.grey.100}",
        "text-primary": "{color.primitive.grey.950}", "text-secondary": "{color.primitive.grey.600}",
        "text-tertiary": "{color.primitive.grey.400}", "text-disabled": "{color.primitive.grey.300}", "text-inverse": "{color.primitive.grey.0}",
        "text-link": "{color.primitive.accent.600}", "text-link-hover": "{color.primitive.accent.700}",
        "border-subtle": "{color.primitive.grey.100}", "border-default": "{color.primitive.grey.200}",
        "border-strong": "{color.primitive.grey.300}", "border-focus": "oklch(0.500 0.220 22 / 0.5)",
        "accent": "{color.primitive.accent.500}", "accent-hover": "{color.primitive.accent.600}",
        "accent-press": "{color.primitive.accent.700}", "accent-subtle": "oklch(0.500 0.220 22 / 0.10)", "accent-text": "{color.primitive.grey.0}",
        "success": "{color.primitive.success}", "success-subtle": "oklch(0.500 0.150 145 / 0.10)", "success-text": "oklch(0.380 0.130 145)",
        "warning": "{color.primitive.warning}", "warning-subtle": "oklch(0.650 0.165 65 / 0.10)", "warning-text": "oklch(0.460 0.140 65)",
        "error": "{color.primitive.error}", "error-subtle": "oklch(0.500 0.220 22 / 0.10)", "error-text": "oklch(0.400 0.190 22)",
        "info": "{color.primitive.info}", "info-subtle": "oklch(0.520 0.150 240 / 0.10)", "info-text": "oklch(0.380 0.130 240)"
      },
      "dark": {
        "bg-base": "{color.primitive.grey.950}", "bg-surface": "{color.primitive.grey.900}", "bg-elevated": "{color.primitive.grey.800}",
        "bg-overlay": "{color.primitive.grey.700}", "bg-inset": "oklch(0.080 0.005 60)",
        "text-primary": "{color.primitive.grey.50}", "text-secondary": "{color.primitive.grey.400}",
        "text-tertiary": "{color.primitive.grey.600}", "text-disabled": "{color.primitive.grey.700}", "text-inverse": "{color.primitive.grey.950}",
        "text-link": "{color.primitive.accent.400}", "text-link-hover": "{color.primitive.accent.200}",
        "border-subtle": "{color.primitive.grey.800}", "border-default": "{color.primitive.grey.700}",
        "border-strong": "{color.primitive.grey.600}", "border-focus": "oklch(0.700 0.190 22 / 0.6)",
        "accent": "{color.primitive.accent.400}", "accent-hover": "{color.primitive.accent.200}",
        "accent-press": "{color.primitive.accent.500}", "accent-subtle": "oklch(0.700 0.190 22 / 0.16)", "accent-text": "{color.primitive.grey.950}",
        "success": "oklch(0.700 0.150 145)", "success-subtle": "oklch(0.700 0.150 145 / 0.12)", "success-text": "oklch(0.840 0.130 145)",
        "warning": "oklch(0.770 0.165 65)", "warning-subtle": "oklch(0.770 0.165 65 / 0.12)", "warning-text": "oklch(0.870 0.140 65)",
        "error": "oklch(0.640 0.220 22)", "error-subtle": "oklch(0.640 0.220 22 / 0.12)", "error-text": "oklch(0.780 0.180 22)",
        "info": "oklch(0.680 0.180 240)", "info-subtle": "oklch(0.680 0.180 240 / 0.12)", "info-text": "oklch(0.820 0.140 240)"
      }
    },
    "component": {
      "button-bg-primary": "{color.semantic.text-primary}", "button-text-primary": "{color.semantic.bg-base}",
      "button-bg-secondary": "transparent", "button-text-secondary": "{color.semantic.text-primary}",
      "button-border-secondary": "{color.semantic.text-primary}",
      "card-bg": "{color.semantic.bg-surface}", "card-border": "{color.semantic.border-subtle}",
      "input-bg": "transparent", "input-border": "{color.semantic.border-default}",
      "modal-bg": "{color.semantic.bg-surface}", "modal-overlay": "oklch(0.100 0.005 60 / 0.6)",
      "drop-cap-color": "{color.semantic.accent}"
    }
  },
  "typography": {
    "font": {
      "display":      "\"Lyon Display\", \"Caslon\", \"Source Serif 4\", Georgia, serif",
      "body":         "\"Charter\", \"Source Serif 4\", \"Iowan Old Style\", Georgia, serif",
      "chrome":       "\"Söhne\", \"Inter\", system-ui, sans-serif",
      "mono":         "\"iA Writer Mono\", \"JetBrains Mono\", monospace"
    },
    "size": {
      "xs":   { "size": "13px", "lineHeight": "1.5", "letterSpacing": "0.01em",  "weight": 400 },
      "sm":   { "size": "15px", "lineHeight": "1.5", "letterSpacing": "0",        "weight": 400 },
      "base": { "size": "19px", "lineHeight": "1.7", "letterSpacing": "0",        "weight": 400 },
      "lg":   { "size": "23px", "lineHeight": "1.5", "letterSpacing": "-0.005em", "weight": 400 },
      "xl":   { "size": "30px", "lineHeight": "1.3", "letterSpacing": "-0.015em", "weight": 500 },
      "2xl":  { "size": "40px", "lineHeight": "1.15","letterSpacing": "-0.025em", "weight": 600 },
      "3xl":  { "size": "54px", "lineHeight": "1.05","letterSpacing": "-0.035em", "weight": 700 },
      "4xl":  { "size": "72px", "lineHeight": "1.0", "letterSpacing": "-0.04em",  "weight": 700 },
      "5xl":  { "size": "96px", "lineHeight": "0.95","letterSpacing": "-0.045em", "weight": 700 }
    }
  },
  "spacing": { "0": "0", "1": "4px", "2": "8px", "3": "12px", "4": "16px", "6": "24px", "8": "32px", "12": "48px", "16": "64px", "24": "96px", "32": "128px" },
  "radius":  { "none": "0", "sm": "0", "md": "0", "lg": "0", "xl": "0", "2xl": "0", "full": "9999px" },
  "border":  { "thin": "1px", "medium": "1.5px", "thick": "2px" },
  "shadow":  { "xs": "none", "sm": "none", "md": "none", "lg": "none", "xl": "none", "focus": "0 0 0 2px oklch(0.500 0.220 22 / 0.5)" },
  "motion": {
    "duration": { "instant": "0ms", "fast": "150ms", "normal": "200ms", "slow": "300ms", "deliberate": "500ms", "spring": "400ms" },
    "easing":   { "out": "cubic-bezier(0, 0, 0.2, 1)", "in": "cubic-bezier(0.4, 0, 1, 1)", "in-out": "cubic-bezier(0.4, 0, 0.2, 1)", "spring": "cubic-bezier(0.34, 1.56, 0.64, 1)" }
  }
}
