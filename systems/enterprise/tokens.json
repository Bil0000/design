{
  "$schema": "design-engine.token.schema.v1",
  "name": "enterprise",
  "version": "1.0.0",
  "modes": ["light", "dark"],
  "default_mode": "light",
  "color": {
    "primitive": {
      "grey": {
        "0": "oklch(1 0 0)", "50": "oklch(0.985 0.003 245)", "100": "oklch(0.965 0.005 245)",
        "200": "oklch(0.920 0.008 245)", "300": "oklch(0.835 0.010 245)", "400": "oklch(0.700 0.012 245)",
        "500": "oklch(0.560 0.012 245)", "600": "oklch(0.430 0.010 245)", "700": "oklch(0.330 0.010 245)",
        "800": "oklch(0.230 0.008 245)", "900": "oklch(0.150 0.006 245)", "950": "oklch(0.090 0.005 245)"
      },
      "accent": {
        "50": "oklch(0.970 0.030 245)", "100": "oklch(0.940 0.060 245)", "200": "oklch(0.880 0.110 245)",
        "300": "oklch(0.800 0.150 245)", "400": "oklch(0.690 0.180 245)", "500": "oklch(0.580 0.180 245)",
        "600": "oklch(0.500 0.180 245)", "700": "oklch(0.420 0.165 245)", "800": "oklch(0.340 0.140 245)",
        "900": "oklch(0.270 0.110 245)", "950": "oklch(0.200 0.080 245)"
      },
      "success": "oklch(0.500 0.150 145)",
      "warning": "oklch(0.640 0.155 65)",
      "error":   "oklch(0.500 0.220 22)",
      "info":    "oklch(0.500 0.180 245)"
    },
    "semantic": {
      "light": {
        "bg-base": "{color.primitive.grey.0}", "bg-surface": "{color.primitive.grey.50}", "bg-elevated": "{color.primitive.grey.100}",
        "bg-overlay": "{color.primitive.grey.200}", "bg-inset": "{color.primitive.grey.50}",
        "text-primary": "{color.primitive.grey.950}", "text-secondary": "{color.primitive.grey.700}",
        "text-tertiary": "{color.primitive.grey.500}", "text-disabled": "{color.primitive.grey.400}", "text-inverse": "{color.primitive.grey.0}",
        "text-link": "{color.primitive.accent.700}", "text-link-hover": "{color.primitive.accent.800}",
        "border-subtle": "{color.primitive.grey.200}", "border-default": "{color.primitive.grey.300}",
        "border-strong": "{color.primitive.grey.500}", "border-focus": "oklch(0.500 0.180 245 / 0.7)",
        "accent": "{color.primitive.accent.600}", "accent-hover": "{color.primitive.accent.700}",
        "accent-press": "{color.primitive.accent.800}", "accent-subtle": "oklch(0.500 0.180 245 / 0.10)", "accent-text": "{color.primitive.grey.0}",
        "success": "{color.primitive.success}", "success-subtle": "oklch(0.500 0.150 145 / 0.10)", "success-text": "oklch(0.380 0.130 145)",
        "warning": "{color.primitive.warning}", "warning-subtle": "oklch(0.640 0.155 65 / 0.10)", "warning-text": "oklch(0.460 0.130 65)",
        "error": "{color.primitive.error}", "error-subtle": "oklch(0.500 0.220 22 / 0.10)", "error-text": "oklch(0.400 0.190 22)",
        "info": "{color.primitive.info}", "info-subtle": "oklch(0.500 0.180 245 / 0.10)", "info-text": "oklch(0.380 0.150 245)"
      },
      "dark": {
        "bg-base": "{color.primitive.grey.950}", "bg-surface": "{color.primitive.grey.900}", "bg-elevated": "{color.primitive.grey.800}",
        "bg-overlay": "{color.primitive.grey.700}", "bg-inset": "{color.primitive.grey.950}",
        "text-primary": "{color.primitive.grey.50}", "text-secondary": "{color.primitive.grey.300}",
        "text-tertiary": "{color.primitive.grey.500}", "text-disabled": "{color.primitive.grey.600}", "text-inverse": "{color.primitive.grey.950}",
        "text-link": "{color.primitive.accent.300}", "text-link-hover": "{color.primitive.accent.200}",
        "border-subtle": "{color.primitive.grey.700}", "border-default": "{color.primitive.grey.600}",
        "border-strong": "{color.primitive.grey.500}", "border-focus": "oklch(0.690 0.180 245 / 0.7)",
        "accent": "{color.primitive.accent.400}", "accent-hover": "{color.primitive.accent.300}",
        "accent-press": "{color.primitive.accent.500}", "accent-subtle": "oklch(0.690 0.180 245 / 0.16)", "accent-text": "{color.primitive.grey.950}",
        "success": "oklch(0.700 0.150 145)", "success-subtle": "oklch(0.700 0.150 145 / 0.12)", "success-text": "oklch(0.840 0.130 145)",
        "warning": "oklch(0.770 0.165 65)", "warning-subtle": "oklch(0.770 0.165 65 / 0.12)", "warning-text": "oklch(0.870 0.140 65)",
        "error": "oklch(0.640 0.220 22)", "error-subtle": "oklch(0.640 0.220 22 / 0.12)", "error-text": "oklch(0.780 0.180 22)",
        "info": "oklch(0.690 0.180 245)", "info-subtle": "oklch(0.690 0.180 245 / 0.12)", "info-text": "oklch(0.820 0.140 245)"
      }
    },
    "component": {
      "button-bg-primary": "{color.semantic.accent}", "button-bg-primary-hover": "{color.semantic.accent-hover}",
      "button-bg-primary-press": "{color.semantic.accent-press}", "button-text-primary": "{color.semantic.accent-text}",
      "button-bg-secondary": "{color.semantic.bg-surface}", "button-text-secondary": "{color.semantic.text-primary}",
      "button-border-secondary": "{color.semantic.border-default}",
      "card-bg": "{color.semantic.bg-base}", "card-border": "{color.semantic.border-default}",
      "input-bg": "{color.semantic.bg-base}", "input-border": "{color.semantic.border-default}", "input-border-focus": "{color.semantic.border-focus}", "input-border-error": "{color.semantic.error}",
      "table-row-bg": "{color.semantic.bg-base}", "table-row-bg-hover": "{color.semantic.bg-surface}", "table-header-bg": "{color.semantic.bg-surface}", "table-cell-border": "{color.semantic.border-default}",
      "modal-bg": "{color.semantic.bg-base}", "modal-overlay": "oklch(0.090 0.005 245 / 0.6)", "modal-border": "{color.semantic.border-default}"
    }
  },
  "typography": {
    "font": {
      "display": "\"IBM Plex Sans\", \"Inter\", system-ui, sans-serif",
      "body":    "\"IBM Plex Sans\", \"Inter\", system-ui, -apple-system, sans-serif",
      "serif":   "\"IBM Plex Serif\", Georgia, serif",
      "mono":    "\"IBM Plex Mono\", \"JetBrains Mono\", monospace"
    },
    "size": {
      "xs":   { "size": "12px", "lineHeight": "1.6", "letterSpacing": "0.01em",  "weight": 400 },
      "sm":   { "size": "14px", "lineHeight": "1.5", "letterSpacing": "0.005em", "weight": 400 },
      "base": { "size": "14px", "lineHeight": "1.5", "letterSpacing": "0",       "weight": 400 },
      "lg":   { "size": "16px", "lineHeight": "1.45","letterSpacing": "-0.005em","weight": 500 },
      "xl":   { "size": "20px", "lineHeight": "1.3", "letterSpacing": "-0.015em","weight": 600 },
      "2xl":  { "size": "28px", "lineHeight": "1.2", "letterSpacing": "-0.025em","weight": 600 },
      "3xl":  { "size": "36px", "lineHeight": "1.15","letterSpacing": "-0.03em", "weight": 600 },
      "4xl":  { "size": "48px", "lineHeight": "1.05","letterSpacing": "-0.035em","weight": 700 }
    }
  },
  "spacing": { "0": "0", "1": "4px", "2": "8px", "3": "12px", "4": "16px", "5": "20px", "6": "24px", "8": "32px", "12": "48px", "16": "64px" },
  "radius":  { "none": "0", "sm": "4px", "md": "4px", "lg": "6px", "xl": "8px", "2xl": "12px", "full": "9999px" },
  "border":  { "thin": "1px", "medium": "2px", "thick": "2px" },
  "shadow": {
    "xs": "0 1px 2px 0 oklch(0 0 0 / 0.05)",
    "sm": "0 2px 4px -1px oklch(0 0 0 / 0.06), 0 1px 2px -1px oklch(0 0 0 / 0.04)",
    "md": "0 4px 8px -2px oklch(0 0 0 / 0.08), 0 2px 4px -2px oklch(0 0 0 / 0.04)",
    "lg": "0 12px 24px -4px oklch(0 0 0 / 0.10), 0 4px 8px -4px oklch(0 0 0 / 0.06)",
    "xl": "0 24px 48px -8px oklch(0 0 0 / 0.14), 0 8px 16px -8px oklch(0 0 0 / 0.08)",
    "focus": "0 0 0 2px var(--bg-base), 0 0 0 4px oklch(0.500 0.180 245)"
  },
  "motion": {
    "duration": { "instant": "0ms", "fast": "120ms", "normal": "240ms", "slow": "320ms", "deliberate": "400ms", "spring": "300ms" },
    "easing":   { "out": "cubic-bezier(0, 0, 0.2, 1)", "in": "cubic-bezier(0.4, 0, 1, 1)", "in-out": "cubic-bezier(0.4, 0, 0.2, 1)", "spring": "cubic-bezier(0.4, 0, 0.2, 1)" }
  }
}
