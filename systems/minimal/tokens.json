{
  "$schema": "design-engine.token.schema.v1",
  "name": "minimal",
  "version": "1.0.0",
  "modes": ["light", "dark"],
  "default_mode": "light",
  "color": {
    "primitive": {
      "grey": {
        "0": "oklch(1 0 0)", "50": "oklch(0.985 0 0)", "100": "oklch(0.960 0 0)",
        "200": "oklch(0.920 0 0)", "300": "oklch(0.840 0 0)", "400": "oklch(0.700 0 0)",
        "500": "oklch(0.560 0 0)", "600": "oklch(0.430 0 0)", "700": "oklch(0.330 0 0)",
        "800": "oklch(0.230 0 0)", "900": "oklch(0.150 0 0)", "950": "oklch(0.080 0 0)"
      },
      "accent": {
        "500": "oklch(0.500 0.140 22)", "600": "oklch(0.430 0.140 22)", "700": "oklch(0.350 0.120 22)"
      },
      "success": "oklch(0.500 0.130 145)", "warning": "oklch(0.640 0.150 65)",
      "error":   "oklch(0.480 0.190 22)",  "info":    "oklch(0.500 0.150 240)"
    },
    "semantic": {
      "light": {
        "bg-base": "{color.primitive.grey.0}", "bg-surface": "{color.primitive.grey.50}", "bg-elevated": "{color.primitive.grey.50}",
        "bg-overlay": "{color.primitive.grey.100}", "bg-inset": "{color.primitive.grey.50}",
        "text-primary": "{color.primitive.grey.950}", "text-secondary": "{color.primitive.grey.600}",
        "text-tertiary": "{color.primitive.grey.400}", "text-disabled": "{color.primitive.grey.300}", "text-inverse": "{color.primitive.grey.0}",
        "text-link": "{color.primitive.grey.950}", "text-link-hover": "{color.primitive.grey.600}",
        "border-subtle": "{color.primitive.grey.100}", "border-default": "{color.primitive.grey.200}",
        "border-strong": "{color.primitive.grey.400}", "border-focus": "oklch(0.430 0.140 22 / 0.6)",
        "accent": "{color.primitive.grey.950}", "accent-hover": "{color.primitive.grey.700}",
        "accent-press": "{color.primitive.grey.800}", "accent-subtle": "oklch(0 0 0 / 0.05)", "accent-text": "{color.primitive.grey.0}",
        "success": "{color.primitive.success}", "success-subtle": "oklch(0.500 0.130 145 / 0.08)", "success-text": "oklch(0.380 0.110 145)",
        "warning": "{color.primitive.warning}", "warning-subtle": "oklch(0.640 0.150 65 / 0.08)", "warning-text": "oklch(0.460 0.130 65)",
        "error": "{color.primitive.error}", "error-subtle": "oklch(0.480 0.190 22 / 0.08)", "error-text": "oklch(0.380 0.170 22)",
        "info": "{color.primitive.info}", "info-subtle": "oklch(0.500 0.150 240 / 0.08)", "info-text": "oklch(0.380 0.130 240)"
      },
      "dark": {
        "bg-base": "{color.primitive.grey.950}", "bg-surface": "{color.primitive.grey.900}", "bg-elevated": "{color.primitive.grey.900}",
        "bg-overlay": "{color.primitive.grey.800}", "bg-inset": "{color.primitive.grey.950}",
        "text-primary": "{color.primitive.grey.50}", "text-secondary": "{color.primitive.grey.400}",
        "text-tertiary": "{color.primitive.grey.600}", "text-disabled": "{color.primitive.grey.700}", "text-inverse": "{color.primitive.grey.950}",
        "text-link": "{color.primitive.grey.50}", "text-link-hover": "{color.primitive.grey.300}",
        "border-subtle": "{color.primitive.grey.800}", "border-default": "{color.primitive.grey.700}",
        "border-strong": "{color.primitive.grey.500}", "border-focus": "oklch(0.700 0.140 22 / 0.6)",
        "accent": "{color.primitive.grey.50}", "accent-hover": "{color.primitive.grey.300}",
        "accent-press": "{color.primitive.grey.200}", "accent-subtle": "oklch(1 0 0 / 0.06)", "accent-text": "{color.primitive.grey.950}"
      }
    },
    "component": {
      "button-bg-primary": "{color.semantic.accent}", "button-text-primary": "{color.semantic.accent-text}",
      "button-bg-secondary": "transparent", "button-text-secondary": "{color.semantic.text-primary}",
      "button-border-secondary": "{color.semantic.text-primary}",
      "card-bg": "transparent", "card-border": "{color.semantic.border-default}",
      "input-bg": "transparent", "input-border": "{color.semantic.border-default}",
      "modal-bg": "{color.semantic.bg-base}", "modal-overlay": "oklch(1 0 0 / 0.85)"
    }
  },
  "typography": {
    "font": {
      "display": "\"Inter Display\", \"Inter\", system-ui, sans-serif",
      "body":    "\"Inter\", system-ui, -apple-system, sans-serif",
      "mono":    "\"iA Writer Mono\", \"JetBrains Mono\", monospace"
    },
    "size": {
      "xs":   { "size": "13px", "lineHeight": "1.55","letterSpacing": "0.01em",  "weight": 400 },
      "sm":   { "size": "15px", "lineHeight": "1.55","letterSpacing": "0",        "weight": 400 },
      "base": { "size": "17px", "lineHeight": "1.65","letterSpacing": "-0.005em", "weight": 400 },
      "lg":   { "size": "22px", "lineHeight": "1.4", "letterSpacing": "-0.015em", "weight": 400 },
      "xl":   { "size": "29px", "lineHeight": "1.25","letterSpacing": "-0.025em", "weight": 500 },
      "2xl":  { "size": "39px", "lineHeight": "1.1", "letterSpacing": "-0.035em", "weight": 500 },
      "3xl":  { "size": "52px", "lineHeight": "1.0", "letterSpacing": "-0.045em", "weight": 600 },
      "4xl":  { "size": "69px", "lineHeight": "0.95","letterSpacing": "-0.05em",  "weight": 600 },
      "5xl":  { "size": "92px", "lineHeight": "0.9", "letterSpacing": "-0.06em",  "weight": 600 }
    }
  },
  "spacing": { "0": "0", "1": "4px", "2": "8px", "3": "12px", "4": "16px", "6": "24px", "8": "32px", "12": "48px", "16": "64px", "24": "96px", "32": "128px", "48": "192px", "64": "256px" },
  "radius":  { "none": "0", "sm": "0", "md": "2px", "lg": "2px", "xl": "2px", "2xl": "2px", "full": "9999px" },
  "border":  { "thin": "1px", "medium": "1px", "thick": "1.5px" },
  "shadow":  { "xs": "none", "sm": "none", "md": "none", "lg": "none", "xl": "none", "focus": "0 0 0 2px oklch(0.430 0.140 22 / 0.4)" },
  "motion": {
    "duration": { "instant": "0ms", "fast": "150ms", "normal": "200ms", "slow": "300ms", "deliberate": "500ms", "spring": "400ms" },
    "easing":   { "out": "cubic-bezier(0, 0, 0.2, 1)", "in": "cubic-bezier(0.4, 0, 1, 1)", "in-out": "cubic-bezier(0.4, 0, 0.2, 1)", "spring": "cubic-bezier(0.34, 1.56, 0.64, 1)" }
  }
}
