{
  "$schema": "design-engine.token.schema.v1",
  "name": "mobile-ios",
  "version": "1.0.0",
  "modes": ["light", "dark"],
  "default_mode": "light",
  "color": {
    "primitive": {
      "grey": {
        "0": "oklch(1.000 0.000 0)", "50": "oklch(0.985 0.000 0)", "100": "oklch(0.960 0.000 0)",
        "200": "oklch(0.920 0.000 0)", "300": "oklch(0.840 0.000 0)", "400": "oklch(0.700 0.000 0)",
        "500": "oklch(0.560 0.000 0)", "600": "oklch(0.430 0.000 0)", "700": "oklch(0.330 0.000 0)",
        "800": "oklch(0.230 0.000 0)", "900": "oklch(0.160 0.000 0)", "950": "oklch(0.100 0.000 0)"
      },
      "system-blue":   "oklch(0.620 0.190 250)",
      "system-green":  "oklch(0.700 0.180 145)",
      "system-orange": "oklch(0.760 0.180 60)",
      "system-red":    "oklch(0.620 0.220 22)",
      "system-yellow": "oklch(0.840 0.150 95)",
      "system-purple": "oklch(0.560 0.180 290)",
      "system-pink":   "oklch(0.700 0.180 350)",
      "system-teal":   "oklch(0.700 0.130 200)",
      "system-indigo": "oklch(0.500 0.180 270)"
    },
    "semantic": {
      "light": {
        "bg-base":         "{color.primitive.grey.50}",
        "bg-surface":      "{color.primitive.grey.0}",
        "bg-elevated":     "{color.primitive.grey.0}",
        "bg-overlay":      "{color.primitive.grey.100}",
        "bg-grouped":      "{color.primitive.grey.50}",
        "label-primary":   "{color.primitive.grey.950}",
        "label-secondary": "oklch(0.430 0 0 / 0.6)",
        "label-tertiary":  "oklch(0.430 0 0 / 0.3)",
        "label-quaternary":"oklch(0.430 0 0 / 0.18)",
        "fill-primary":    "oklch(0.430 0 0 / 0.20)",
        "fill-secondary":  "oklch(0.430 0 0 / 0.16)",
        "fill-tertiary":   "oklch(0.430 0 0 / 0.12)",
        "fill-quaternary": "oklch(0.430 0 0 / 0.08)",
        "separator":       "oklch(0.430 0 0 / 0.36)",
        "separator-opaque":"{color.primitive.grey.300}",
        "border-focus":    "oklch(0.620 0.190 250 / 0.5)",
        "accent":          "{color.primitive.system-blue}",
        "accent-text":     "{color.primitive.grey.0}",
        "success":         "{color.primitive.system-green}",
        "warning":         "{color.primitive.system-orange}",
        "error":           "{color.primitive.system-red}",
        "info":            "{color.primitive.system-blue}"
      },
      "dark": {
        "bg-base":         "{color.primitive.grey.950}",
        "bg-surface":      "{color.primitive.grey.900}",
        "bg-elevated":     "{color.primitive.grey.800}",
        "bg-overlay":      "{color.primitive.grey.700}",
        "bg-grouped":      "oklch(0 0 0)",
        "label-primary":   "{color.primitive.grey.0}",
        "label-secondary": "oklch(0.940 0 0 / 0.6)",
        "label-tertiary":  "oklch(0.940 0 0 / 0.3)",
        "label-quaternary":"oklch(0.940 0 0 / 0.18)",
        "fill-primary":    "oklch(0.940 0 0 / 0.36)",
        "fill-secondary":  "oklch(0.940 0 0 / 0.32)",
        "fill-tertiary":   "oklch(0.940 0 0 / 0.24)",
        "fill-quaternary": "oklch(0.940 0 0 / 0.18)",
        "separator":       "oklch(0.940 0 0 / 0.65)",
        "separator-opaque":"{color.primitive.grey.700}",
        "border-focus":    "oklch(0.700 0.190 250 / 0.6)",
        "accent":          "oklch(0.700 0.190 250)",
        "accent-text":     "{color.primitive.grey.0}",
        "success":         "oklch(0.760 0.180 145)",
        "warning":         "oklch(0.820 0.180 60)",
        "error":           "oklch(0.700 0.220 22)",
        "info":            "oklch(0.700 0.190 250)"
      }
    },
    "component": {
      "button-bg-primary":     "{color.semantic.accent}",
      "button-text-primary":   "{color.semantic.accent-text}",
      "button-bg-secondary":   "{color.semantic.fill-tertiary}",
      "button-text-secondary": "{color.semantic.accent}",
      "card-bg":               "{color.semantic.bg-surface}",
      "card-border":           "{color.semantic.separator}",
      "input-bg":              "{color.semantic.fill-quaternary}",
      "input-text":            "{color.semantic.label-primary}",
      "input-placeholder":     "{color.semantic.label-tertiary}",
      "modal-bg":              "{color.semantic.bg-elevated}",
      "modal-overlay":         "oklch(0 0 0 / 0.4)",
      "tabbar-bg":             "{color.semantic.bg-base}",
      "navbar-bg":             "{color.semantic.bg-base}"
    }
  },
  "typography": {
    "font": {
      "display":     "-apple-system, \"SF Pro Display\", \"Inter Display\", system-ui, sans-serif",
      "body":        "-apple-system, \"SF Pro Text\", \"Inter\", system-ui, sans-serif",
      "rounded":     "-apple-system-ui-rounded, \"SF Pro Rounded\", system-ui, sans-serif",
      "mono":        "ui-monospace, \"SF Mono\", \"JetBrains Mono\", monospace"
    },
    "size": {
      "caption-2":   { "size": "11px", "lineHeight": "1.27", "letterSpacing": "0.005em",  "weight": 400 },
      "caption-1":   { "size": "12px", "lineHeight": "1.33", "letterSpacing": "0",         "weight": 400 },
      "footnote":    { "size": "13px", "lineHeight": "1.38", "letterSpacing": "-0.005em",  "weight": 400 },
      "subhead":     { "size": "15px", "lineHeight": "1.33", "letterSpacing": "-0.01em",   "weight": 400 },
      "callout":     { "size": "16px", "lineHeight": "1.31", "letterSpacing": "-0.015em",  "weight": 400 },
      "body":        { "size": "17px", "lineHeight": "1.29", "letterSpacing": "-0.022em",  "weight": 400 },
      "headline":    { "size": "17px", "lineHeight": "1.29", "letterSpacing": "-0.022em",  "weight": 600 },
      "title-3":     { "size": "20px", "lineHeight": "1.25", "letterSpacing": "-0.022em",  "weight": 400 },
      "title-2":     { "size": "22px", "lineHeight": "1.27", "letterSpacing": "-0.026em",  "weight": 400 },
      "title-1":     { "size": "28px", "lineHeight": "1.21", "letterSpacing": "-0.022em",  "weight": 400 },
      "large-title": { "size": "34px", "lineHeight": "1.21", "letterSpacing": "-0.022em",  "weight": 700 }
    }
  },
  "spacing": { "0": "0", "1": "4px", "2": "8px", "3": "12px", "4": "16px", "5": "20px", "6": "24px", "8": "32px", "12": "48px", "16": "64px" },
  "radius":  { "none": "0", "sm": "6px", "md": "10px", "lg": "14px", "xl": "20px", "2xl": "28px", "full": "9999px" },
  "border":  { "thin": "0.5px", "medium": "1px", "thick": "2px" },
  "touch":   { "min": "44px" },
  "shadow": {
    "xs": "0 1px 1px 0 oklch(0 0 0 / 0.05)",
    "sm": "0 1px 3px 0 oklch(0 0 0 / 0.08)",
    "md": "0 4px 12px 0 oklch(0 0 0 / 0.10)",
    "lg": "0 12px 32px 0 oklch(0 0 0 / 0.14)",
    "xl": "0 24px 48px 0 oklch(0 0 0 / 0.16)",
    "focus": "0 0 0 4px oklch(0.620 0.190 250 / 0.30)"
  },
  "blur": {
    "thin":          "blur(20px) saturate(180%)",
    "regular":       "blur(40px) saturate(180%)",
    "thick":         "blur(60px) saturate(180%)",
    "ultra-thin":    "blur(10px) saturate(180%)"
  },
  "motion": {
    "duration": { "instant": "0ms", "fast": "150ms", "normal": "250ms", "slow": "350ms", "deliberate": "500ms", "spring": "550ms" },
    "easing":   { "out": "cubic-bezier(0, 0, 0.2, 1)", "in": "cubic-bezier(0.4, 0, 1, 1)", "in-out": "cubic-bezier(0.4, 0, 0.2, 1)", "spring": "cubic-bezier(0.32, 0.72, 0, 1)" }
  }
}
