{
  "$schema": "design-engine.token.schema.v1",
  "name": "mobile-material",
  "version": "1.0.0",
  "modes": ["light", "dark"],
  "default_mode": "light",
  "color": {
    "primitive": {
      "neutral": {
        "0": "oklch(1.000 0.000 0)", "10": "oklch(0.110 0.005 250)", "20": "oklch(0.190 0.008 250)",
        "30": "oklch(0.270 0.010 250)", "40": "oklch(0.380 0.012 250)", "50": "oklch(0.490 0.012 250)",
        "60": "oklch(0.580 0.012 250)", "70": "oklch(0.680 0.012 250)", "80": "oklch(0.780 0.010 250)",
        "90": "oklch(0.880 0.008 250)", "95": "oklch(0.940 0.005 250)", "99": "oklch(0.985 0.003 250)", "100": "oklch(1.000 0.000 0)"
      },
      "primary": {
        "10": "oklch(0.150 0.080 280)", "20": "oklch(0.230 0.110 280)", "30": "oklch(0.310 0.135 280)",
        "40": "oklch(0.420 0.140 280)", "50": "oklch(0.530 0.150 280)", "60": "oklch(0.620 0.150 280)",
        "70": "oklch(0.720 0.140 280)", "80": "oklch(0.810 0.110 280)", "90": "oklch(0.890 0.080 280)",
        "95": "oklch(0.940 0.050 280)", "99": "oklch(0.985 0.020 280)"
      },
      "secondary": {
        "10": "oklch(0.150 0.040 220)", "30": "oklch(0.310 0.060 220)", "40": "oklch(0.420 0.070 220)",
        "60": "oklch(0.620 0.080 220)", "80": "oklch(0.810 0.060 220)", "90": "oklch(0.890 0.045 220)"
      },
      "tertiary": {
        "10": "oklch(0.150 0.060 30)", "30": "oklch(0.310 0.080 30)", "40": "oklch(0.420 0.090 30)",
        "60": "oklch(0.620 0.100 30)", "80": "oklch(0.810 0.080 30)", "90": "oklch(0.890 0.060 30)"
      },
      "error": {
        "10": "oklch(0.150 0.090 22)", "20": "oklch(0.230 0.130 22)", "30": "oklch(0.310 0.170 22)",
        "40": "oklch(0.420 0.200 22)", "60": "oklch(0.620 0.220 22)", "80": "oklch(0.810 0.150 22)", "90": "oklch(0.890 0.100 22)"
      }
    },
    "semantic": {
      "light": {
        "primary":             "{color.primitive.primary.40}",
        "on-primary":          "{color.primitive.neutral.100}",
        "primary-container":   "{color.primitive.primary.90}",
        "on-primary-container":"{color.primitive.primary.10}",
        "secondary":           "{color.primitive.secondary.40}",
        "on-secondary":        "{color.primitive.neutral.100}",
        "secondary-container": "{color.primitive.secondary.90}",
        "on-secondary-container":"{color.primitive.secondary.10}",
        "tertiary":            "{color.primitive.tertiary.40}",
        "on-tertiary":         "{color.primitive.neutral.100}",
        "tertiary-container":  "{color.primitive.tertiary.90}",
        "error":               "{color.primitive.error.40}",
        "on-error":            "{color.primitive.neutral.100}",
        "error-container":     "{color.primitive.error.90}",
        "on-error-container":  "{color.primitive.error.10}",
        "background":          "{color.primitive.neutral.99}",
        "on-background":       "{color.primitive.neutral.10}",
        "surface":             "{color.primitive.neutral.99}",
        "surface-variant":     "{color.primitive.neutral.90}",
        "on-surface":          "{color.primitive.neutral.10}",
        "on-surface-variant":  "{color.primitive.neutral.30}",
        "outline":             "{color.primitive.neutral.50}",
        "outline-variant":     "{color.primitive.neutral.80}",
        "scrim":               "oklch(0 0 0)",
        "shadow":              "oklch(0 0 0)",
        "border-focus":        "{color.primitive.primary.40}"
      },
      "dark": {
        "primary":             "{color.primitive.primary.80}",
        "on-primary":          "{color.primitive.primary.20}",
        "primary-container":   "{color.primitive.primary.30}",
        "on-primary-container":"{color.primitive.primary.90}",
        "secondary":           "{color.primitive.secondary.80}",
        "on-secondary":        "{color.primitive.secondary.10}",
        "secondary-container": "{color.primitive.secondary.30}",
        "tertiary":            "{color.primitive.tertiary.80}",
        "on-tertiary":         "{color.primitive.tertiary.10}",
        "tertiary-container":  "{color.primitive.tertiary.30}",
        "error":               "{color.primitive.error.80}",
        "on-error":            "{color.primitive.error.20}",
        "error-container":     "{color.primitive.error.30}",
        "on-error-container":  "{color.primitive.error.90}",
        "background":          "{color.primitive.neutral.10}",
        "on-background":       "{color.primitive.neutral.90}",
        "surface":             "{color.primitive.neutral.10}",
        "surface-variant":     "{color.primitive.neutral.30}",
        "on-surface":          "{color.primitive.neutral.90}",
        "on-surface-variant":  "{color.primitive.neutral.80}",
        "outline":             "{color.primitive.neutral.60}",
        "outline-variant":     "{color.primitive.neutral.30}",
        "scrim":               "oklch(0 0 0)",
        "shadow":              "oklch(0 0 0)",
        "border-focus":        "{color.primitive.primary.80}"
      }
    },
    "component": {
      "fab-bg":          "{color.semantic.primary-container}",
      "fab-text":        "{color.semantic.on-primary-container}",
      "appbar-bg":       "{color.semantic.surface}",
      "navbar-bg":       "{color.semantic.surface}",
      "card-bg":         "{color.semantic.surface}",
      "card-border":     "{color.semantic.outline-variant}",
      "input-bg":        "{color.semantic.surface-variant}",
      "input-text":      "{color.semantic.on-surface}",
      "input-border":    "{color.semantic.outline}",
      "modal-bg":        "{color.semantic.surface}",
      "modal-overlay":   "oklch(0 0 0 / 0.4)"
    }
  },
  "typography": {
    "font": {
      "display": "\"Google Sans\", \"Roboto\", system-ui, sans-serif",
      "body":    "\"Roboto\", system-ui, -apple-system, sans-serif",
      "mono":    "\"Roboto Mono\", \"JetBrains Mono\", monospace"
    },
    "size": {
      "display-large":  { "size": "57px", "lineHeight": "1.12", "letterSpacing": "-0.005em",  "weight": 400 },
      "display-medium": { "size": "45px", "lineHeight": "1.16", "letterSpacing": "0",          "weight": 400 },
      "display-small":  { "size": "36px", "lineHeight": "1.22", "letterSpacing": "0",          "weight": 400 },
      "headline-large": { "size": "32px", "lineHeight": "1.25", "letterSpacing": "0",          "weight": 400 },
      "headline-medium":{ "size": "28px", "lineHeight": "1.29", "letterSpacing": "0",          "weight": 400 },
      "headline-small": { "size": "24px", "lineHeight": "1.33", "letterSpacing": "0",          "weight": 400 },
      "title-large":    { "size": "22px", "lineHeight": "1.27", "letterSpacing": "0",          "weight": 400 },
      "title-medium":   { "size": "16px", "lineHeight": "1.5",  "letterSpacing": "0.009em",    "weight": 500 },
      "title-small":    { "size": "14px", "lineHeight": "1.43", "letterSpacing": "0.007em",    "weight": 500 },
      "body-large":     { "size": "16px", "lineHeight": "1.5",  "letterSpacing": "0.031em",    "weight": 400 },
      "body-medium":    { "size": "14px", "lineHeight": "1.43", "letterSpacing": "0.018em",    "weight": 400 },
      "body-small":     { "size": "12px", "lineHeight": "1.33", "letterSpacing": "0.033em",    "weight": 400 },
      "label-large":    { "size": "14px", "lineHeight": "1.43", "letterSpacing": "0.007em",    "weight": 500 },
      "label-medium":   { "size": "12px", "lineHeight": "1.33", "letterSpacing": "0.041em",    "weight": 500 },
      "label-small":    { "size": "11px", "lineHeight": "1.45", "letterSpacing": "0.045em",    "weight": 500 }
    }
  },
  "spacing": { "0": "0", "1": "4px", "2": "8px", "3": "12px", "4": "16px", "5": "20px", "6": "24px", "8": "32px", "10": "40px", "12": "48px", "16": "64px" },
  "radius":  { "none": "0", "xs": "4px", "sm": "8px", "md": "12px", "lg": "16px", "xl": "28px", "full": "9999px" },
  "border":  { "thin": "1px", "medium": "1.5px", "thick": "2px" },
  "touch":   { "min": "48px" },
  "elevation": {
    "0": "none",
    "1": "0 1px 2px 0 oklch(0 0 0 / 0.30), 0 1px 3px 1px oklch(0 0 0 / 0.15)",
    "2": "0 1px 2px 0 oklch(0 0 0 / 0.30), 0 2px 6px 2px oklch(0 0 0 / 0.15)",
    "3": "0 4px 8px 3px oklch(0 0 0 / 0.15), 0 1px 3px 0 oklch(0 0 0 / 0.30)",
    "4": "0 6px 10px 4px oklch(0 0 0 / 0.15), 0 2px 3px 0 oklch(0 0 0 / 0.30)",
    "5": "0 8px 12px 6px oklch(0 0 0 / 0.15), 0 4px 4px 0 oklch(0 0 0 / 0.30)"
  },
  "motion": {
    "duration": { "instant": "0ms", "fast": "100ms", "normal": "200ms", "slow": "300ms", "deliberate": "500ms", "spring": "550ms" },
    "easing":   { "out": "cubic-bezier(0, 0, 0, 1)", "in": "cubic-bezier(0.3, 0, 1, 1)", "in-out": "cubic-bezier(0.2, 0, 0, 1)", "emphasized": "cubic-bezier(0.2, 0, 0, 1)", "spring": "cubic-bezier(0.34, 1.56, 0.64, 1)" }
  }
}
