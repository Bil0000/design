        "text-secondary":  "{color.primitive.grey.400}",
        "text-tertiary":   "{color.primitive.grey.600}",
        "text-disabled":   "{color.primitive.grey.700}",
        "text-inverse":    "{color.primitive.grey.950}",
        "text-link":       "{color.primitive.accent.400}",
        "text-link-hover": "{color.primitive.accent.300}",
        "border-subtle":   "{color.primitive.grey.800}",
        "border-default":  "{color.primitive.grey.700}",
        "border-strong":   "{color.primitive.grey.600}",
        "border-focus":    "oklch(0.700 0.130 220 / 0.6)",
        "accent":          "{color.primitive.accent.400}",
