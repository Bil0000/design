        "text-disabled":   "{color.primitive.grey.300}",
        "text-inverse":    "{color.primitive.grey.0}",
        "text-link":       "{color.primitive.accent.600}",
        "text-link-hover": "{color.primitive.accent.700}",
        "border-subtle":   "{color.primitive.grey.100}",
