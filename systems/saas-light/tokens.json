{
  "$schema": "design-engine.token.schema.v1",
  "name": "saas-light",
  "version": "1.0.0",
  "modes": ["light", "dark"],
  "default_mode": "light",
  "color": {
    "primitive": {
      "grey": {
        "0": "oklch(1.000 0.000 0)",
        "50": "oklch(0.985 0.003 240)",
        "100": "oklch(0.965 0.005 240)",
        "200": "oklch(0.920 0.008 240)",
        "300": "oklch(0.835 0.010 240)",
        "400": "oklch(0.700 0.012 240)",
        "500": "oklch(0.560 0.012 240)",
        "600": "oklch(0.430 0.010 240)",
        "700": "oklch(0.330 0.010 240)",
        "800": "oklch(0.230 0.008 240)",
        "900": "oklch(0.160 0.006 240)",
        "950": "oklch(0.110 0.005 240)"
      },
      "accent": {
        "50": "oklch(0.970 0.030 152)", "100": "oklch(0.940 0.060 152)", "200": "oklch(0.890 0.110 152)",
        "300": "oklch(0.810 0.150 152)", "400": "oklch(0.700 0.170 152)", "500": "oklch(0.620 0.180 152)",
        "600": "oklch(0.550 0.180 152)", "700": "oklch(0.470 0.165 152)", "800": "oklch(0.380 0.140 152)",
        "900": "oklch(0.300 0.110 152)", "950": "oklch(0.220 0.080 152)"
      },
      "success": "oklch(0.580 0.180 145)",
      "warning": "oklch(0.720 0.170 65)",
      "error":   "oklch(0.580 0.220 22)",
      "info":    "oklch(0.620 0.180 240)",
      "chart": {
        "1": "oklch(0.620 0.180 152)", "2": "oklch(0.700 0.170 65)", "3": "oklch(0.620 0.150 145)",
        "4": "oklch(0.700 0.150 95)", "5": "oklch(0.640 0.180 280)", "6": "oklch(0.700 0.180 30)",
        "7": "oklch(0.640 0.140 200)", "8": "oklch(0.500 0.012 240)"
      }
    },
    "semantic": {
      "light": {
        "bg-base": "{color.primitive.grey.0}", "bg-surface": "{color.primitive.grey.50}", "bg-elevated": "{color.primitive.grey.100}",
        "bg-overlay": "{color.primitive.grey.200}", "bg-inset": "{color.primitive.grey.100}",
        "text-primary": "{color.primitive.grey.900}", "text-secondary": "{color.primitive.grey.600}",
        "text-tertiary": "{color.primitive.grey.400}", "text-disabled": "{color.primitive.grey.300}", "text-inverse": "{color.primitive.grey.0}",
        "text-link": "{color.primitive.accent.600}", "text-link-hover": "{color.primitive.accent.700}",
        "border-subtle": "{color.primitive.grey.100}", "border-default": "{color.primitive.grey.200}",
        "border-strong": "{color.primitive.grey.300}", "border-focus": "oklch(0.550 0.180 152 / 0.6)",
        "accent": "{color.primitive.accent.600}", "accent-hover": "{color.primitive.accent.700}",
        "accent-press": "{color.primitive.accent.800}", "accent-subtle": "oklch(0.550 0.180 152 / 0.10)", "accent-text": "{color.primitive.grey.0}",
        "success": "{color.primitive.success}", "success-subtle": "oklch(0.580 0.180 145 / 0.10)", "success-text": "oklch(0.420 0.150 145)",
        "warning": "{color.primitive.warning}", "warning-subtle": "oklch(0.720 0.170 65 / 0.10)", "warning-text": "oklch(0.500 0.140 65)",
        "error": "{color.primitive.error}", "error-subtle": "oklch(0.580 0.220 22 / 0.10)", "error-text": "oklch(0.440 0.190 22)",
        "info": "{color.primitive.info}", "info-subtle": "oklch(0.620 0.180 240 / 0.10)", "info-text": "oklch(0.420 0.150 240)"
      },
      "dark": {
        "bg-base": "{color.primitive.grey.950}", "bg-surface": "{color.primitive.grey.900}", "bg-elevated": "{color.primitive.grey.800}",
        "bg-overlay": "{color.primitive.grey.700}", "bg-inset": "oklch(0.080 0.005 240)",
        "text-primary": "{color.primitive.grey.50}", "text-secondary": "{color.primitive.grey.400}",
        "text-tertiary": "{color.primitive.grey.600}", "text-disabled": "{color.primitive.grey.700}", "text-inverse": "{color.primitive.grey.950}",
        "text-link": "{color.primitive.accent.400}", "text-link-hover": "{color.primitive.accent.300}",
        "border-subtle": "{color.primitive.grey.800}", "border-default": "{color.primitive.grey.700}",
        "border-strong": "{color.primitive.grey.600}", "border-focus": "oklch(0.700 0.170 152 / 0.6)",
        "accent": "{color.primitive.accent.400}", "accent-hover": "{color.primitive.accent.300}",
        "accent-press": "{color.primitive.accent.500}", "accent-subtle": "oklch(0.700 0.170 152 / 0.16)", "accent-text": "{color.primitive.grey.950}",
        "success": "oklch(0.700 0.170 145)", "success-subtle": "oklch(0.700 0.170 145 / 0.12)", "success-text": "oklch(0.840 0.140 145)",
        "warning": "oklch(0.770 0.170 65)", "warning-subtle": "oklch(0.770 0.170 65 / 0.12)", "warning-text": "oklch(0.870 0.140 65)",
        "error": "oklch(0.640 0.220 22)", "error-subtle": "oklch(0.640 0.220 22 / 0.12)", "error-text": "oklch(0.780 0.180 22)",
        "info": "oklch(0.680 0.180 240)", "info-subtle": "oklch(0.680 0.180 240 / 0.12)", "info-text": "oklch(0.820 0.140 240)"
      }
    },
    "component": {
      "button-bg-primary": "{color.semantic.accent}", "button-bg-primary-hover": "{color.semantic.accent-hover}",
      "button-bg-primary-press": "{color.semantic.accent-press}", "button-text-primary": "{color.semantic.accent-text}",
      "button-bg-secondary": "{color.semantic.bg-surface}", "button-text-secondary": "{color.semantic.text-primary}",
      "button-border-secondary": "{color.semantic.border-default}",
      "card-bg": "{color.semantic.bg-base}", "card-border": "{color.semantic.border-subtle}", "card-bg-hover": "{color.semantic.bg-surface}",
      "input-bg": "{color.semantic.bg-base}", "input-border": "{color.semantic.border-default}", "input-border-focus": "{color.semantic.border-focus}", "input-border-error": "{color.semantic.error}",
      "modal-bg": "{color.semantic.bg-base}", "modal-overlay": "oklch(0.110 0.005 240 / 0.5)", "modal-border": "{color.semantic.border-subtle}",
      "toast-bg": "{color.semantic.bg-base}", "badge-bg": "{color.semantic.bg-surface}", "badge-text": "{color.semantic.text-primary}",
      "nav-bg": "{color.semantic.bg-base}", "nav-text": "{color.semantic.text-secondary}", "nav-text-active": "{color.semantic.text-primary}", "nav-bg-active": "{color.semantic.bg-surface}",
      "table-row-bg": "{color.semantic.bg-base}", "table-row-bg-hover": "{color.semantic.bg-surface}", "table-header-bg": "{color.semantic.bg-surface}", "table-cell-border": "{color.semantic.border-subtle}"
    }
  },
  "typography": {
    "font": {
      "display": "\"Inter Display\", \"Inter\", system-ui, sans-serif",
      "body":    "\"Inter\", system-ui, -apple-system, sans-serif",
      "mono":    "\"JetBrains Mono\", \"Fira Code\", monospace"
    },
    "size": {
      "xs":   { "size": "12px", "lineHeight": "1.6", "letterSpacing": "0.005em","weight": 400 },
      "sm":   { "size": "14px", "lineHeight": "1.55","letterSpacing": "0",       "weight": 400 },
      "base": { "size": "15px", "lineHeight": "1.55","letterSpacing": "-0.005em","weight": 400 },
      "lg":   { "size": "18px", "lineHeight": "1.45","letterSpacing": "-0.01em", "weight": 500 },
      "xl":   { "size": "22px", "lineHeight": "1.3", "letterSpacing": "-0.02em", "weight": 600 },
      "2xl":  { "size": "30px", "lineHeight": "1.2", "letterSpacing": "-0.03em", "weight": 600 },
      "3xl":  { "size": "40px", "lineHeight": "1.1", "letterSpacing": "-0.04em", "weight": 700 },
      "4xl":  { "size": "56px", "lineHeight": "1.0", "letterSpacing": "-0.05em", "weight": 700 }
    }
  },
  "spacing": { "0": "0", "1": "4px", "2": "8px", "3": "12px", "4": "16px", "6": "24px", "8": "32px", "12": "48px", "16": "64px", "24": "96px", "32": "128px" },
  "radius":  { "none": "0", "sm": "4px", "md": "6px", "lg": "8px", "xl": "12px", "2xl": "16px", "full": "9999px" },
  "border":  { "thin": "1px", "medium": "1.5px", "thick": "2px" },
  "shadow": {
    "xs": "0 1px 2px 0 oklch(0.110 0.005 240 / 0.05)",
    "sm": "0 2px 4px -1px oklch(0.110 0.005 240 / 0.06), 0 1px 2px -1px oklch(0.110 0.005 240 / 0.04)",
    "md": "0 4px 8px -2px oklch(0.110 0.005 240 / 0.08), 0 2px 4px -2px oklch(0.110 0.005 240 / 0.04)",
    "lg": "0 12px 24px -4px oklch(0.110 0.005 240 / 0.10), 0 4px 8px -4px oklch(0.110 0.005 240 / 0.06)",
    "xl": "0 24px 48px -8px oklch(0.110 0.005 240 / 0.14), 0 8px 16px -8px oklch(0.110 0.005 240 / 0.08)",
    "focus": "0 0 0 3px oklch(0.550 0.180 152 / 0.30)"
  },
  "motion": {
    "duration": { "instant": "0ms", "fast": "100ms", "normal": "150ms", "slow": "250ms", "deliberate": "400ms", "spring": "350ms" },
    "easing":   { "out": "cubic-bezier(0, 0, 0.2, 1)", "in": "cubic-bezier(0.4, 0, 1, 1)", "in-out": "cubic-bezier(0.4, 0, 0.2, 1)", "spring": "cubic-bezier(0.34, 1.56, 0.64, 1)" }
  }
}
